model User {
  id             String    @id @default(cuid())
  email          String    @unique
  phone          String?   @unique
  erpId          String?   @unique
  role           Role      @default(student)
  passwordHash   String
  firstName      String?
  lastName       String?
  isVerified     Boolean   @default(false)
